# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="IntelliTrace SCF Sentinel"
DEBUG=false
ENVIRONMENT=production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=intellitrace
POSTGRES_PASSWORD=intellitrace_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=intellitrace

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Fraud Engine Thresholds ───────────────────────────────────────────────────
REVENUE_RATIO_THRESHOLD=2.0
CASCADE_DEPTH_THRESHOLD=3
VELOCITY_WINDOW_DAYS=30
VELOCITY_THRESHOLD=20
HIGH_RISK_SCORE_THRESHOLD=70.0

# ── CORS ─────────────────────────────────────────────────────────────────────
# Add your frontend origin here
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
